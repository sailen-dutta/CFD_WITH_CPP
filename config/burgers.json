{
    "mesh":{
        "x0" : 0.0,
        "x1" : 1.0,
        "nx" : 501
    },

    "simulation" : {
        "t_final" : 0.2,
        "cfl" : 0.5
    },

    "physics" : {
        "equation" : "burgers"
    },

    "initial_condition" : {
        "type" : "gaussian",

        "gaussian" : {
            "center" : 0.5,
            "sigma" : 0.08
        },

        "square_pulse" : {
            "x_start" : 0.25,
            "x_end"   : 0.50,
            "value"   : 1.0
        }
    },

    "numerics" : {
        "flux" : "rusanov",
        "reconstruction" : {
            "type" : "muscl",
            "limiter" : "minmod"
        },
        "spatial_operator" : "finite_volume",
        "time_integrator" : "ssprk3"
    },

    "output" : {
        "format" : "tecplot",
        "frequency" : 5,
        "directory" : "output"
    }

}