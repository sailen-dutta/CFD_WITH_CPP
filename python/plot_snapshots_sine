import glob
import math

import matplotlib.pyplot as plt
import numpy as np

# Numerical parameters
dt = 0.005
output_frequency = 10
c = 1.0

# Exact solution
def exact_sine(x,t,c):
    return np.sin(4.0 * np.pi * (x - c * t))

# Load output files
files = sorted(glob.glob("output/*.csv"))

print(f"Found {len(files)} files. ")

if(len(files) == 0):
    raise RuntimeError("No output files found.")

# Subplots layout
nplots = len(files)
ncols = 3
nrows = math.ceil(nplots / ncols)

# Create figure
fig, axes = plt.subplots(nrows, ncols, figsize=(15,4*nrows))

# Flatten axes array
axes = np.array(axes).flatten()

# Plot snapshots
for i, filename in enumerate(files):
    # Load numerical solution
    x,u = np.loadtxt(filename, delimiter=",", skiprows=1, unpack=True)
    # Physical time
    t = i * output_frequency * dt

    u_exact = exact_sine(x,t,c)

    # Numerical solution
    axes[i].plot(x,u,linewidth=2,label="Numerical")

    # Exact solution
    axes[i].plot(x,u_exact,linestyle="--",linewidth=2,label="Exact")

    # Format axes
    axes[i].set_xlim(0.0,1.0)
    axes[i].set_ylim(-1.2,1.2)
    axes[i].set_title(f"t = {t:.3f}")
    axes[i].grid(True)
    axes[i].legend()

# Hide unused subplots
for j in range(i+1, len(axes)):
    axes[j].axis("off")

fig.suptitle("1D Linear Advection: Exact vs Numerical", fontsize=18)

plt.tight_layout()
plt.show()
